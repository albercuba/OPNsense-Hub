# Application
APP_NAME=OPNsense Hub
APP_ENV=development
APP_TIMEZONE=Europe/Berlin
HUB_PUBLIC_URL=http://localhost:8083
PUBLIC_URL=http://localhost:8083

# Database and secrets
DATABASE_URL=postgresql+psycopg://opnsensehub:opnsensehub@opnsense-hub-db:5432/opnsensehub
SECRET_KEY=change-me-to-a-long-random-value
SECRET_ENCRYPTION_KEY=
CSRF_COOKIE_NAME=opnsense_hub_csrf
SESSION_COOKIE_NAME=opnsense_hub_session
SESSION_SECURE=false
SESSION_TTL_HOURS=12
OTP_TTL_MINUTES=10

# Initial administrator
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me

# WireGuard and tunnel policy
HUB_WG_ENDPOINT=localhost:51820
HUB_WG_CIDR=100.96.0.0/16
HUB_WG_ADDRESS=100.96.0.1/16
HUB_WG_LISTEN_PORT=51820
ALLOW_BROAD_WG_CIDR=false
WG_INTERFACE=wg0
WG_CONFIG_PATH=/etc/wireguard/wg0.conf
WG_SERVER_PRIVATE_KEY_PATH=/etc/wireguard/server.key
WG_SERVER_PUBLIC_KEY=auto-generated-when-WG_DRY_RUN-is-false
WG_DRY_RUN=false
HUB_ENABLE_IP_FORWARDING=false
HUB_MANAGE_FIREWALL_RULES=true

# Proxy and firewall UI access
PROXY_VERIFY_TLS=false
ALLOW_INSECURE_PROXY_TLS_IN_PRODUCTION=false
OPNSENSE_GUI_PORT=443

# Branding storage
BRANDING_UPLOAD_DIR=/var/lib/opnsense-hub/branding
BRANDING_LOGO_MAX_BYTES=1000000

# Firewall health checks
FIREWALL_HEALTH_CHECK_INTERVAL_SECONDS=60
FIREWALL_HEALTH_CHECK_TIMEOUT_SECONDS=15
FIREWALL_HEALTH_WARNING_MISSES=3
FIREWALL_HEALTH_CRITICAL_MISSES=4
FIREWALL_HEALTH_WARNING_RECOVERY_SUCCESSES=1
FIREWALL_HEALTH_CRITICAL_RECOVERY_SUCCESSES=2

# Rate limits
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_LOCAL_AD_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOCAL_AD_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_MICROSOFT_LOGIN_ATTEMPTS=10
RATE_LIMIT_MICROSOFT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_ENROLLMENT_ATTEMPTS=10
RATE_LIMIT_ENROLLMENT_WINDOW_SECONDS=300
RATE_LIMIT_ENROLLMENT_CODE_ATTEMPTS=10
RATE_LIMIT_ENROLLMENT_CODE_WINDOW_SECONDS=300
RATE_LIMIT_DEVICE_HEARTBEAT_ATTEMPTS=120
RATE_LIMIT_DEVICE_HEARTBEAT_WINDOW_SECONDS=60
RATE_LIMIT_DEVICE_BACKUP_ATTEMPTS=20
RATE_LIMIT_DEVICE_BACKUP_WINDOW_SECONDS=300
RATE_LIMIT_BACKUP_RESTORE_ATTEMPTS=3
RATE_LIMIT_BACKUP_RESTORE_WINDOW_SECONDS=900

# Log retention and archive management
LOG_RETENTION_ENABLED=true
LOG_RETENTION_RUN_ON_STARTUP=true
AUDIT_LOG_RETENTION_DAYS=365
DEVICE_EVENT_RETENTION_DAYS=90
AUDIT_LOG_MIN_RETENTION_DAYS=30
DEVICE_EVENT_MIN_RETENTION_DAYS=7
LOG_RETENTION_SWEEP_INTERVAL_HOURS=24
LOG_RETENTION_DELETE_BATCH_SIZE=5000
AUDIT_DEVICE_VIEW_THROTTLE_MINUTES=15

# Database migrations
RUN_DB_MIGRATIONS_ON_STARTUP=true
ALLOW_LEGACY_SCHEMA_BOOTSTRAP=true
